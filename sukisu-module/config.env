# Package name of the modified Conceal FlClash Android APK.
FLCLASH_PACKAGE=com.github.ychaiyi.conceal_flclash

# Activity used by FlClash for no-UI quick actions.
FLCLASH_START_ACTION=com.github.ychaiyi.conceal_flclash.action.START
FLCLASH_STOP_ACTION=com.github.ychaiyi.conceal_flclash.action.STOP

# Start the app once during late_start service. The app still uses its own
# Android VpnService TUN implementation; grant VPN consent once in the app UI.
FLCLASH_AUTO_START=1
FLCLASH_WAIT_TUN_SECONDS=45
