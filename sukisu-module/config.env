# Package name of the modified Conceal FlClash Android APK.
FLCLASH_PACKAGE=com.github.ychaiyi.conceal_flclash

# Start the root TUN process during late_start service.
FLCLASH_AUTO_START=1
FLCLASH_AUTO_START_RETRY=1
FLCLASH_WAIT_CONFIG_SECONDS=60
FLCLASH_WAIT_TUN_SECONDS=45
FLCLASH_APP_DIR=/data/user/0/com.github.ychaiyi.conceal_flclash/files

# Route Android primary-user apps through the root-created TUN, while keeping
# root and Android system services outside the TUN.
FLCLASH_INCLUDE_ANDROID_USERS=0
FLCLASH_EXCLUDE_UIDS=
FLCLASH_EXCLUDE_UID_RANGES=0:9999
FLCLASH_IPROUTE_TABLE=2022
FLCLASH_IPROUTE_RULE_START=9000
FLCLASH_IPROUTE_RULE_END=9010
FLCLASH_LOG_LEVEL=info
FLCLASH_FORCE_SNIFFER=1
FLCLASH_TUN_STACK=gvisor

# Keep the root mihomo DNS service internal to TUN hijack. Leaving this empty
# avoids binding the app core's local DNS port, usually 127.0.0.1:9053.
FLCLASH_DNS_LISTEN=
FLCLASH_DNS_ENHANCED_MODE=redir-host
